# Open Brain — Environment Variables
# Copy this file to .env and fill in your values

# Supabase (get from: Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep secret — never expose publicly

# OpenAI (get from: platform.openai.com → API Keys)
# Used for: generating vector embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Anthropic (get from: console.anthropic.com → API Keys)
# Used for: metadata extraction (type, topics, people, action items)
ANTHROPIC_API_KEY=sk-ant-...
